# vim: ft=gitconfig
[user]
    name = alanfzf
    email = 29936954+alanfzf@users.noreply.github.com
    signingkey = ~/.ssh/id_ed25519.pub
[commit]
    gpgsign = true
[gpg]
    format = ssh
[push]
    autoSetupRemote = true
[core]
    editor = nvim
    autocrlf = false
    pager = cat
[init]
    defaultBranch = main
[pull]
    rebase = true
[mergetool]
    keepBackup = false
[alias]
    subup = submodule update --init --recursive
    co = checkout
    cob = checkout -b
    br = branch
    st = status
    cm = commit -m
    amend = commit --amend -m
    po = push origin
    cp = cherry-pick
    dfc = diff --check
    rmcache = rm -rf --cached .
    rbc = !git add -A && git rebase --continue
    rba = rebase --abort
    mt = mergetool
    gone = !git fetch -p && git for-each-ref --format '%(refname:short) %(upstream:track)' | awk '$2 == \"[gone]\" {print $1}' | xargs -r git branch -D
[diff]
    tool = nvim_difftool
[difftool "nvim_difftool"]
    cmd = nvim -c \"packadd nvim.difftool\" -c \"DiffTool $LOCAL $REMOTE\"
